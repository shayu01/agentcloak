{
  "manifest_version": 3,
  "name": "Turnstile Patcher",
  "version": "1.0",
  "description": "Patches screenX/screenY to bypass CDP mouse event detection",
  "content_scripts": [
    {
      "js": ["script.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
