{
  "manifest_version": 3,
  "name": "browserctl Bridge",
  "version": "1.1",
  "description": "Remote browser control bridge for browserctl",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab",
    "debugger",
    "scripting",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "browserctl Bridge"
  }
}
